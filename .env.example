# ============================================
# BACKEND ENVIRONMENT VARIABLES
# ============================================

# Database
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/gamerverse?schema=public

# JWT Authentication
JWT_SECRET=replace_with_a_secure_random_secret
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_EXPIRES_IN=30d

# App Configuration
CLIENT_ORIGIN=http://localhost:5173
SERVER_PORT=4000

# OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback

# Supabase Storage
SUPABASE_URL=https://your-supabase-url
SUPABASE_KEY=your-supabase-key

# ============================================
# FRONTEND ENVIRONMENT VARIABLES
# ============================================
# Note: Frontend variables must be prefixed with VITE_ to be exposed to the client

# API Base URL (for production, use your backend URL)
# For development, this is typically proxied through Vite
VITE_API_BASE_URL=http://localhost:4000/api

# Socket.io Server URL (for production, use your backend URL with ws:// or wss://)
VITE_SOCKET_URL=http://localhost:4000
